RewriteEngine On
RewriteBase /kyros-helpdesk/

# Bloquear acceso directo a directorios sensibles
RewriteRule ^(app|config|database|vendor)/ - [F,L]

# Servir assets reales directamente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Todo el resto va al front-controller
RewriteRule ^ index.php [QSA,L]

# Seguridad
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<FilesMatch "\.(env|sql|md|json|lock)$">
    Require all denied
</FilesMatch>
